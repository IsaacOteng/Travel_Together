DEBUG=True
SECRET_KEY=replace-with-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL + PostGIS
DATABASE_URL=postgis://postgres:yourpassword@localhost:5432/travel_together

# Redis (leave blank to use in-memory channel layer for dev)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# Email
# Local dev: console backend prints emails to the terminal.
# Production: switch to smtp and fill in Brevo credentials.
#   Sign up at brevo.com → SMTP & API → SMTP tab → copy the SMTP key as EMAIL_HOST_PASSWORD.
#   EMAIL_HOST_USER is your Brevo login email.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Google OAuth (for social-auth, separate from Firebase)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase Admin SDK — paste the full service-account JSON as a single line
FIREBASE_SERVICE_ACCOUNT_JSON=

# GeoDjango — Windows only (remove on Linux/Mac)
GDAL_LIBRARY_PATH=C:\Program Files\PostgreSQL\16\bin\libgdal-35.dll
GEOS_LIBRARY_PATH=C:\Program Files\PostgreSQL\16\bin\libgeos_c.dll

# Cloudflare R2 object storage
# Local dev: leave USE_R2=False — files are saved to the local media/ folder.
# Production: set USE_R2=True and fill in the four values below.
#   dash.cloudflare.com → R2 → create bucket → Manage R2 API tokens → create token (Object Read & Write)
#   R2_ENDPOINT_URL format: https://<account_id>.r2.cloudflarestorage.com
#   R2_PUBLIC_DOMAIN: optional custom domain (e.g. media.traveltogether.app)
USE_R2=False
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_PUBLIC_DOMAIN=

# Africa's Talking SMS (optional)
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER=TravelTogether
